<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="ChipFilter" parent="Widget.MaterialComponents.Chip.Filter">
        <item name="chipBackgroundColor">@color/grey_light</item>
        <item name="chipStrokeColor">@color/divider</item>
        <item name="chipStrokeWidth">0.5dp</item>
        <item name="android:textSize">13sp</item>
        <item name="chipMinHeight">34dp</item>
        <item name="rippleColor">@color/primary_soft</item>
        <item name="android:textColor">@color/grey_dark</item>
        <item name="checkedIconVisible">true</item>
        <item name="chipIconTint">@color/grey_dark</item>
    </style>

    <style name="ButtonPrimary" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/primary</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="elevation">0dp</item>
    </style>
</resources>